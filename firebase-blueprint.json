{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher"] }
      },
      "required": ["uid", "email"]
    },
    "Module": {
      "title": "Module",
      "description": "A learning module containing videos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "title", "order"]
    },
    "Video": {
      "title": "Video",
      "description": "A video within a module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "youtubeId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "moduleId", "youtubeId", "title"]
    },
    "Progress": {
      "title": "Progress",
      "description": "User progress on a video",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "completed": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "videoId", "completed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/modules/{moduleId}": {
      "schema": "Module",
      "description": "Learning modules"
    },
    "/modules/{moduleId}/videos/{videoId}": {
      "schema": "Video",
      "description": "Videos within modules"
    },
    "/progress/{progressId}": {
      "schema": "Progress",
      "description": "User progress records"
    }
  }
}
